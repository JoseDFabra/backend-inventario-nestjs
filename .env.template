# ===========================================
# Copiar a .env y ajustar. No commitear .env.
# ===========================================
#
# DESARROLLO (Postgres en Docker): docker compose up -d
#   → DB_HOST=localhost  DB_PORT=5433  (no DB_SSL)
# QA / Producción (Aurora en AWS):
#   → DB_HOST=aurora-xxx.cluster-xxx.region.rds.amazonaws.com  DB_PORT=5432  DB_SSL=true
# ===========================================

APP_ENV=dev
PORT=3000
NODE_ENV=development

# Base de datos: desarrollo = Docker (5433); QA = Aurora (5432 + DB_SSL=true)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=inventory
DB_USER=postgres
DB_PASSWORD=postgres
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Opcionales: pool y timeout (por defecto 10 y 10000 ms)
# DB_POOL_SIZE=10
# DB_CONNECT_TIMEOUT_MS=10000

# -------------------------------------------
# CORS (prod: URL del frontend; dev/qa: true o *)
# -------------------------------------------
CORS_ORIGIN=true

# -------------------------------------------
# JWT (cambiar en producción)
# -------------------------------------------
JWT_SECRET=change-in-prod
